# Default to normalized text handling for the repository.
* text=auto

# Keep source, config, docs, and cube payloads on LF across platforms.
*.py text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cube text eol=lf

# ComfyUI consumes this compiler-owned deployment tree.
web/** linguist-generated=true

# Windows-native scripts should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
